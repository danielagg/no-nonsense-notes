<resources>
    <style name="Theme.NoNonsenseNotes" parent="android:style/Theme.Material.NoActionBar">
        <item name="android:fontFamily">sans</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:statusBarColor">@color/brand_ink</item>
        <item name="android:navigationBarColor">@color/brand_ink</item>
        <item name="android:windowActionModeOverlay">true</item>
    </style>

    <style name="Theme.NoNonsenseNotes.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/brand_ink</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_mark</item>
        <item name="windowSplashScreenAnimationDuration">280</item>
        <item name="postSplashScreenTheme">@style/Theme.NoNonsenseNotes</item>
    </style>
</resources>

